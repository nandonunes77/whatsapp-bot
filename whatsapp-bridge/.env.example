# ============================================
# Configurações do WhatsApp Bridge
# ============================================
# Copie este arquivo para .env e ajuste conforme necessário

# Servidor Python (FastAPI)
BOT_SERVER=http://localhost:8000

# ============================================
# Proteção contra ban
# ============================================
# Máximo de QR codes antes de pausar (padrão: 5)
# MAX_QR_CODES=5

# Tempo de pausa após atingir limite (em minutos, padrão: 5)
# QR_PAUSE_MINUTES=5

# Delay base para reconexão (em segundos, padrão: 5)
# RECONNECT_BASE_SECONDS=5

# Delay máximo para reconexão (em segundos, padrão: 60)
# RECONNECT_MAX_SECONDS=60
