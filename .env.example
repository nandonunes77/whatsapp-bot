# ═══════════════════════════════════════════
# CONFIGURAÇÃO DO CHATBOT WHATSAPP
# ═══════════════════════════════════════════
# Copie este arquivo como .env e preencha os valores
# cp .env.example .env

# ──────────────────────────────────────────
# DEEPSEEK API (INTELIGÊNCIA ARTIFICIAL)
# ──────────────────────────────────────────
# Chave da API DeepSeek para responder perguntas
# Obtenha em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sua_chave_aqui

# ──────────────────────────────────────────
# WHATSAPP (conexão via whatsapp-web.js)
# ──────────────────────────────────────────
# Número do WhatsApp que o bot vai usar (com código do país)
# Ex: 5511999998888 (Brasil, 11, 99999-8888)
BOT_NUMERO=5511999998888

# ──────────────────────────────────────────
# SERVIDOR (onde o bot vai rodar)
# ──────────────────────────────────────────
# Porta do servidor Python
BOT_PORTA=8000
