# Chaves de API e configurações sensíveis
.env
.env.local
*.key
*cred*.json
*secret*.json

# Sessão do WhatsApp (credenciais de login)
whatsapp-bridge/whatsapp-auth/
whatsapp-bridge/*.auth/

